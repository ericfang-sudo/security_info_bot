# TWCERT 企業會員（僅 TWCERT 流程需要）
TWCERT_ACCOUNT=
TWCERT_PASSWORD=

# Google Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview

# Google Service Account（擇一設定）
GOOGLE_SA_JSON_B64=
# GOOGLE_SA_JSON_FILE=./service_account.json

# Google Sheet / Drive
GOOGLE_SHEET_ID=
GOOGLE_DRIVE_IOC_FOLDER_ID=

# Mattermost Webhooks
MATTERMOST_WEBHOOK=
MATTERMOST_OPS_WEBHOOK=

# 開發模式：使用 tests/fixtures 樣板資料
USE_FIXTURE_DATA=true
